# Copier en .env (gitignoré) et adapter si besoin.
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=app

# L'API lit cette variable pour se connecter à la DB.
# Hôte "db" = nom du service Postgres dans Compose.
DATABASE_URL=postgres://user:pass@db:5432/app

# Tag d'image (utilisé par le pipeline CI/CD).
TAG=latest
